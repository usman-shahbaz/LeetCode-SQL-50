def convert(s, numRows):

    if numRows == 1 or numRows > len(s):
        return s
    
    rows = [""] * numRows
    cr = 0
    gd = False

    for ch in s:

        rows[cr] += ch

        if cr == 0:
            gd = True

        elif cr == numRows - 1:
            gd = False

        if gd:
            cr += 1
        else:
            cr -= 1

    return ''.join(rows)
